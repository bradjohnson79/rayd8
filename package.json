{
  "name": "rayd8-amrita",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:web": "npm --prefix web run dev",
    "dev:hamsa": "cd hamsa && npx expo start --web --port 8081 --host localhost",
    "dev:api": "npm --prefix api run dev",
    "build:web": "npm --prefix web run build",
    "build:hamsa": "cd hamsa && npx expo export --platform web",
    "build:api": "npm --prefix api run build",
    "lint:web": "npm --prefix web run lint",
    "lint:hamsa": "npm --prefix hamsa run lint",
    "db:generate": "npm --prefix api run db:generate"
  }
}
