{
  "name": "api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "postinstall": "npm run build && node scripts/migrate-on-render.mjs",
    "start": "node dist/server.js",
    "test:smoke": "vitest run src/services/notifications/notifications.smoke.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.13",
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "@mux/mux-node": "^14.0.1",
    "@neondatabase/serverless": "^1.1.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-raw-body": "^5.0.0",
    "openai": "^6.35.0",
    "postgres": "^3.4.9",
    "puppeteer": "^24.42.0",
    "resend": "^6.12.2",
    "stripe": "^22.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
